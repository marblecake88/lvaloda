# Telegram Bot (get from @BotFather)
BOT_TOKEN=123456:your-bot-token-here

# xAI (Grok) API — https://console.x.ai/
XAI_API_KEY=xai-...
XAI_MODEL=grok-4-fast
XAI_IMAGE_MODEL=grok-imagine-image

# OpenAI (for Whisper STT + TTS)
OPENAI_API_KEY=sk-...
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# Mini App URL (ngrok URL during dev, прод хост потом)
WEBAPP_URL=https://your-ngrok.ngrok-free.app

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./lvaloda.db

# Reminder defaults
DEFAULT_REMINDER_TIME=19:00
TIMEZONE=Europe/Riga
